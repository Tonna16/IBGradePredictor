{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IB Grade Predictor Historical Example",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mean",
    "recent_mean",
    "std",
    "slope",
    "test_count",
    "ia_estimate",
    "ia_progress",
    "recency_mean_days",
    "recency_std_days",
    "latest_days_ago",
    "final_percentage"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "mean": {"type": "number", "minimum": 0, "maximum": 100},
    "recent_mean": {"type": "number", "minimum": 0, "maximum": 100},
    "std": {"type": "number", "minimum": 0},
    "slope": {"type": "number"},
    "test_count": {"type": "number", "minimum": 1},
    "ia_estimate": {"type": "number", "minimum": 0, "maximum": 100},
    "ia_progress": {"type": "number", "minimum": 0, "maximum": 100},
    "recency_mean_days": {"type": "number", "minimum": 0},
    "recency_std_days": {"type": "number", "minimum": 0},
    "latest_days_ago": {"type": "number", "minimum": 0},
    "final_percentage": {"type": "number", "minimum": 0, "maximum": 100}
  }
}
